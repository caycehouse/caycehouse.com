---
import Layout from "@layouts/Layout.astro"
import Feature from "@components/Feature.astro"
import SocialNav from "@components/SocialNav.astro"

const role = "Systems Administrator";
const certs = ["CCENT", "CCNA", "Jamf Certified Associate"];
const roleWithCerts = [role, ...certs].join(", ");
---
<Layout title={role}>
  <Feature />
  <h1 class="text-2xl md:text-7xl md:font-light">Cayce House</h1>
  <h2 class="mt-2 text-4xl hidden md:block">{role}</h2>
  <h2 class="mt-2 md:hidden">{roleWithCerts}</h2>
  <SocialNav />
</Layout>
