---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import Layout from "@layouts/Layout.astro";
import { formatDate, readingTime } from "@lib/format";

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);
const minutes = readingTime(post.body ?? "");
---

<Layout
  title={post.data.title}
  description={post.data.description}
  type="article"
>
  <article class="mx-auto max-w-3xl">
    <a href="/blog" class="text-sm text-indigo-400 hover:underline">← All posts</a>
    <header class="mt-4 mb-8 border-b border-white/10 pb-6">
      <h1 class="text-3xl font-light md:text-5xl">{post.data.title}</h1>
      <p class="mt-3 text-sm text-white/60">
        <time datetime={post.data.pubDate.toISOString()}>
          {formatDate(post.data.pubDate)}
        </time>
        <span> · {minutes} min read</span>
        {
          post.data.updatedDate && (
            <span> · updated {formatDate(post.data.updatedDate)}</span>
          )
        }
      </p>
      {
        post.data.tags.length > 0 && (
          <ul class="mt-4 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <li>
                <a
                  href={`/blog/tags/${tag}/`}
                  class="rounded-full bg-white/10 px-3 py-1 text-xs text-white/80 hover:bg-white/20"
                >
                  #{tag}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="prose prose-invert max-w-none prose-a:text-indigo-400">
      <Content />
    </div>
  </article>
</Layout>
