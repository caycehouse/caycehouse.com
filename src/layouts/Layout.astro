---
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";
import EasterEgg from "@components/EasterEgg.astro";
import "@styles/global.css";

interface Props {
  title?: string | undefined;
  description?: string | undefined;
  image?: string | undefined;
  type?: "website" | "article" | undefined;
  noindex?: boolean | undefined;
}

const { title, description, image, type, noindex } = Astro.props;
---

<html lang="en">
  <head>
    <Head {title} {description} {image} {type} {noindex} />
  </head>
  <body>
    <div class="flex min-h-screen flex-col bg-black/60" id="content">
      <EasterEgg />
      <Header />
      <main class="flex-1">
        <div class="container mx-auto px-4 py-12">
          <slot />
        </div>
      </main>
      <footer class="border-t border-white/10 bg-black/50 p-4 text-center print:hidden">
        <span class="text-sm text-white/70">
          Copyright © {new Date().getFullYear()} Cayce House
        </span>
      </footer>
    </div>
  </body>
</html>
