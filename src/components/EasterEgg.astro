<script>
  import KonamiCode from 'konami-code-js';

  new KonamiCode(() => {
    // ponytail: plain YouTube iframe instead of yt-player, which dragged in
    // Node's `events` module and a build-time polyfill. Konami is a user
    // gesture, so autoplay-with-sound is allowed.
    const id = '5mGuCdlCcNM';
    const iframe = document.createElement('iframe');
    iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&loop=1&playlist=${id}&controls=0`;
    iframe.allow = 'autoplay; fullscreen';
    iframe.style.cssText =
      'position:fixed;inset:0;width:100vw;height:100vh;border:0;z-index:50';
    document.body.style.overflow = 'hidden';
    document.body.appendChild(iframe);
  });
</script>
